  <model name="prismatic_joint">
    <link name="heavy_base">
      <!-- position the base such that the bottom touches the floor -->
      <pose>0 0 0.05 0 0 0</pose>
      <inertial>
        <mass>100</mass>
        <!-- kg -->
        <inertia>
          <!-- (mass / 12) * (y*y + z*z) -->
