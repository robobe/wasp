    <joint name="prismatic_demo" type="prismatic">
      <parent>prismatic_base</parent>
      <child>prismatic_slide</child>
      <axis>
        <xyz>0 1 0</xyz>
        <!-- Make it springy to keep the demo moving -->
        <limit>
          <lower>-0.25</lower>
          <upper>0.25</upper>
