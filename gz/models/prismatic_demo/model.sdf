    <joint name="prismatic_base_to_heavy_base" type="fixed">
      <parent>heavy_base</parent>
      <child>prismatic_base</child>
    </joint>
    <link name="prismatic_slide">
      <!-- Put the slide near the top of the base -->
      <pose>0.2 0 0.55 0 0 0</pose>
      <inertial>
        <inertia>
          <!-- (mass / 12) * (y*y + z*z) -->
          <ixx>0.0060417</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <!-- (mass / 12) * (x*x + z*z) -->
          <iyy>0.0060417</iyy>
          <iyz>0</iyz>
          <!-- (mass / 12) * (y*y + x*x) -->
